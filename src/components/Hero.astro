---
import { Image } from 'astro:assets';
import bridgeImg from '../assets/bridge.jpg';
---

<section id="heroSection" class="relative w-full h-screen overflow-hidden flex items-center justify-center bg-cyber-darker">
  
  <!-- Scenic Bridge Parallax Background Image -->
  <div class="absolute inset-0 z-0">
    <Image 
      src={bridgeImg} 
      alt="Scenic Bridge Cherry Blossoms" 
      class="hero-bg-img w-full h-full object-cover object-center transform origin-center scale-105 filter brightness-[0.4] contrast-[1.1] saturate-[0.8]"
      loading="eager"
    />
    <!-- Futuristic Dark Radial Tech Gradients -->
    <div class="absolute inset-0 bg-gradient-to-t from-cyber-darker via-transparent to-cyber-darker/60 z-10"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_40%,#060810_100%)] z-10"></div>
  </div>

  <!-- Hero Content Glassmorphic Console -->
  <div class="relative z-20 max-w-4xl mx-auto px-6 text-center hero-content">
    <div class="hero-glass-box glass-panel-cyan p-8 lg:p-16 rounded-3xl relative overflow-hidden shadow-2xl">
      <!-- Glow node -->
      <div class="absolute -top-16 -left-16 w-32 h-32 bg-cyber-blue/10 rounded-full blur-2xl"></div>
      <div class="absolute -bottom-16 -right-16 w-32 h-32 bg-cyber-rose/10 rounded-full blur-2xl"></div>

      <!-- Tagline -->
      <span class="hero-title-line block font-outfit text-xs lg:text-sm tracking-[0.3em] uppercase text-cyber-blue font-semibold mb-6">
        Creative & Inventive Mind
      </span>

      <!-- Headline -->
      <h1 class="hero-title-line font-outfit text-4xl sm:text-6xl lg:text-7xl font-extrabold text-white tracking-tight uppercase leading-none mb-6">
        Jonathan <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyber-blue via-cyber-gold to-cyber-rose text-cyber-glow">Hannon</span>
      </h1>

      <!-- Subheadline -->
      <p class="hero-title-line font-exo text-sm sm:text-base lg:text-lg text-cyber-gray max-w-2xl mx-auto tracking-wide leading-relaxed mb-8">
        Forging the intersection of premium creative design, precise system engineering, and inventive future-focused concepts.
      </p>

      <!-- Buttons -->
      <div class="hero-title-line flex flex-col sm:flex-row items-center justify-center gap-4">
        <a 
          href="#about" 
          class="w-full sm:w-auto font-outfit text-xs tracking-widest uppercase font-semibold text-cyber-dark bg-cyber-blue px-8 py-4 rounded-full shadow-lg shadow-cyber-blue/20 hover:bg-white hover:shadow-white/10 transition-all duration-300 transform hover:-translate-y-0.5"
        >
          Explore Vision
        </a>
        <a 
          href="#contact" 
          class="w-full sm:w-auto font-outfit text-xs tracking-widest uppercase font-semibold text-white border border-white/20 px-8 py-4 rounded-full hover:border-cyber-blue hover:text-cyber-blue transition-all duration-300"
        >
          Get In Touch
        </a>
      </div>
    </div>
  </div>

  <!-- Floating Scroll Indicator -->
  <div class="absolute bottom-10 left-1/2 transform -translate-x-1/2 z-20 flex flex-col items-center opacity-70 hover:opacity-100 transition-opacity duration-300">
    <span class="font-outfit text-[10px] tracking-[0.4em] uppercase text-cyber-gray mb-3">Scroll</span>
    <a href="#about" aria-label="Scroll Down" class="w-6 h-10 border-2 border-cyber-gray/30 rounded-full flex justify-center p-1.5 cursor-pointer">
      <div class="w-1 h-2 bg-cyber-blue rounded-full animate-bounce"></div>
    </a>
  </div>

</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

    // Register ScrollTrigger with GSAP
    gsap.registerPlugin(ScrollTrigger);

    // Zoom and fade background image on scroll
    gsap.to('.hero-bg-img', {
      scale: 1.28,
      y: '8%',
      opacity: 0.1,
      scrollTrigger: {
        trigger: '#heroSection',
        start: 'top top',
        end: 'bottom top',
        scrub: true
      }
    });

    // Fade and slide content glass box upwards on scroll
    gsap.to('.hero-content', {
      opacity: 0,
      y: -60,
      scrollTrigger: {
        trigger: '#heroSection',
        start: 'top top',
        end: '80% top',
        scrub: true
      }
    });

    // Smooth page entry animations
    gsap.from('.hero-glass-box', {
      scale: 0.96,
      opacity: 0,
      duration: 1.4,
      ease: 'power3.out'
    });

    gsap.from('.hero-title-line', {
      y: 35,
      opacity: 0,
      duration: 1.0,
      stagger: 0.15,
      delay: 0.3,
      ease: 'power3.out'
    });
  });
</script>
