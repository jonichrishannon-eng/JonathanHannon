---
import { Image } from "astro:assets";
import portraitImg from "../assets/portrait.jpg";
---

<section
  id="about"
  class="relative w-full min-h-screen py-24 lg:py-32 px-6 lg:px-16 bg-cyber-darker flex items-center overflow-hidden z-10"
>
  <!-- Subtle tech light nodes -->
  <div
    class="absolute top-1/4 right-0 w-[500px] h-[500px] bg-cyber-blue/5 rounded-full blur-[120px] pointer-events-none z-0"
  >
  </div>
  <div
    class="absolute bottom-1/4 left-0 w-[400px] h-[400px] bg-cyber-rose/5 rounded-full blur-[100px] pointer-events-none z-0"
  >
  </div>

  <div
    class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 items-center relative z-10"
  >
    <!-- Left Column: Library Suit Portrait with Cybernetic Frame -->
    <div class="lg:col-span-5 flex justify-center bio-portrait-wrapper">
      <div class="relative group w-full max-w-[380px] lg:max-w-none">
        <!-- Background Tech Glow -->
        <div
          class="absolute -inset-1.5 bg-gradient-to-r from-cyber-blue to-cyber-rose rounded-3xl blur opacity-30 group-hover:opacity-70 transition duration-1000 group-hover:duration-200"
        >
        </div>

        <!-- Main Portrait Container -->
        <div
          class="relative aspect-[3/4] w-full bg-cyber-darker rounded-2xl overflow-hidden border border-white/10 p-2 shadow-2xl"
        >
          <!-- Image Layer -->
          <div class="w-full h-full rounded-xl overflow-hidden relative">
            <Image
              src={portraitImg}
              alt="Jonathan Hannon in Library"
              class="w-full h-full object-cover object-center transform transition-transform duration-700 ease-out group-hover:scale-105 filter brightness-[0.9] contrast-[1.05]"
            />
            <!-- Cyber Glass Glare Overlay -->
            <div
              class="absolute inset-0 bg-gradient-to-tr from-cyber-blue/10 via-transparent to-white/10 opacity-60 pointer-events-none transition-all duration-500 group-hover:opacity-20"
            >
            </div>
          </div>
        </div>

        <!-- Cybernetic Corner Elements -->
        <div
          class="absolute -top-1 -left-1 w-6 h-6 border-t-2 border-l-2 border-cyber-blue rounded-tl-lg pointer-events-none"
        >
        </div>
        <div
          class="absolute -top-1 -right-1 w-6 h-6 border-t-2 border-r-2 border-cyber-blue rounded-tr-lg pointer-events-none"
        >
        </div>
        <div
          class="absolute -bottom-1 -left-1 w-6 h-6 border-b-2 border-l-2 border-cyber-blue rounded-bl-lg pointer-events-none"
        >
        </div>
        <div
          class="absolute -bottom-1 -right-1 w-6 h-6 border-b-2 border-r-2 border-cyber-blue rounded-br-lg pointer-events-none"
        >
        </div>
      </div>
    </div>

    <!-- Right Column: Biography Copy (Exo 2 Typography) -->
    <div class="lg:col-span-7 flex flex-col justify-center bio-text-column">
      <span
        class="font-outfit text-xs lg:text-sm tracking-[0.3em] uppercase text-cyber-blue font-semibold mb-3"
      >
        Professional & Creative
      </span>

      <h2
        class="font-outfit text-3xl sm:text-5xl font-extrabold text-white tracking-tight uppercase leading-none mb-8"
      >
        Bridging Artistry <br />
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-cyber-blue to-cyber-gold"
          >And Scientific Precision</span
        >
      </h2>

      <!-- Small body text using Exo 2 -->
      <div
        class="font-exo text-sm sm:text-base text-cyber-gray space-y-6 leading-relaxed mb-10 max-w-2xl"
      >
        <p>
          I operate at the vanguard of creative design and precise engineering.
          My approach is defined by an absolute refusal of generic templates,
          seeking instead to create custom, immersive digital architectures that
          are both functional masterpieces and aesthetically breathtaking.
        </p>
        <p>
          Every pixel, line of code, and animation is placed with extreme
          mathematical intent. Drawing inspiration from future tech, minimal
          aesthetics, and interactive kinetics, my work bridges raw visual
          storytelling with scalable, performant architectures built to excel
          across all devices and boundaries.
        </p>
      </div>

      <!-- Tech Feature Cards Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl">
        <!-- Card 1 -->
        <div
          class="glass-panel p-6 rounded-2xl border border-white/5 hover:border-cyber-blue/20 transition-all duration-300 group"
        >
          <div
            class="w-10 h-10 rounded-xl bg-cyber-blue/10 flex items-center justify-center text-cyber-blue mb-4 group-hover:scale-110 transition-transform duration-300"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="w-5 h-5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9.53 16.122l.75-2.524 2.525-.75 2.524.75-.75 2.525-2.525.75-2.524-.75z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12.75 6a.75.75 0 00-1.5 0v3.75a.75.75 0 001.5 0V6zM12 15a.75.75 0 110-1.5.75.75 0 010 1.5z"
              ></path>
            </svg>
          </div>
          <h3
            class="font-outfit text-base font-bold text-white mb-2 uppercase tracking-wide"
          >
            Creative Direction
          </h3>
          <p class="font-exo text-xs text-cyber-gray/80 leading-relaxed">
            High-concept artistic engineering designed to spark human curiosity
            and engagement.
          </p>
        </div>

        <!-- Card 2 -->
        <div
          class="glass-panel p-6 rounded-2xl border border-white/5 hover:border-cyber-rose/20 transition-all duration-300 group"
        >
          <div
            class="w-10 h-10 rounded-xl bg-cyber-rose/10 flex items-center justify-center text-cyber-rose mb-4 group-hover:scale-110 transition-transform duration-300"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="w-5 h-5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M14.25 9.75L16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z"
              ></path>
            </svg>
          </div>
          <h3
            class="font-outfit text-base font-bold text-white mb-2 uppercase tracking-wide"
          >
            Precise Development
          </h3>
          <p class="font-exo text-xs text-cyber-gray/80 leading-relaxed">
            Bulletproof systems utilizing Astro, modern engines, and
            mathematically sound UI logic.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    if (typeof gsap === "undefined" || typeof ScrollTrigger === "undefined")
      return;

    // Register ScrollTrigger with GSAP
    gsap.registerPlugin(ScrollTrigger);

    // Fade and slide portrait column on scroll entry
    gsap.from(".bio-portrait-wrapper", {
      opacity: 0,
      x: -40,
      duration: 1.2,
      scrollTrigger: {
        trigger: "#about",
        start: "top 75%",
        end: "bottom bottom",
        toggleActions: "play none none none",
      },
    });

    // Fade and slide text/info column on scroll entry
    gsap.from(".bio-text-column", {
      opacity: 0,
      y: 40,
      duration: 1.0,
      delay: 0.2,
      scrollTrigger: {
        trigger: "#about",
        start: "top 75%",
        end: "bottom bottom",
        toggleActions: "play none none none",
      },
    });
  });
</script>
