---
import { Image } from 'astro:assets';
import pideaImg from '../assets/pidea.jpg';
---

<section id="pidea" class="relative w-full py-24 lg:py-32 px-6 lg:px-16 bg-cyber-darker flex flex-col justify-center items-center overflow-hidden border-t border-b border-white/5 z-10">
  
  <!-- Glowing golden orb backdrop -->
  <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-cyber-gold/5 rounded-full blur-[140px] pointer-events-none z-0"></div>

  <div class="max-w-7xl mx-auto w-full relative z-10 flex flex-col items-center">
    
    <!-- Central PIDEA Logo Orb -->
    <div class="pidea-logo-container mb-12 flex flex-col items-center select-none">
      <div class="relative w-36 h-36 lg:w-44 lg:h-44 rounded-full bg-cyber-darker/60 flex items-center justify-center p-6 border border-cyber-gold/20 shadow-2xl relative group overflow-hidden">
        <!-- Golden breathing glow background -->
        <div class="absolute inset-0 bg-cyber-gold/5 rounded-full animate-pulse"></div>
        <div class="absolute -inset-1 bg-gradient-to-r from-cyber-gold/20 to-transparent rounded-full blur-sm group-hover:from-cyber-gold/40 transition duration-500"></div>
        
        <!-- Screen-blended Golden Logo -->
        <div class="w-full h-full relative z-10 transition-transform duration-500 group-hover:scale-105">
          <Image 
            src={pideaImg} 
            alt="PIDEA Golden Logo" 
            class="w-full h-full object-contain filter invert hue-rotate-180 brightness-110 mix-blend-screen scale-110"
          />
        </div>
      </div>
      
      <!-- Philosophy tagline -->
      <span class="font-outfit text-xs tracking-[0.4em] uppercase text-cyber-gold font-bold mt-6 text-cyber-glow">
        Innovation is the Future
      </span>
    </div>

    <!-- Section Heading -->
    <div class="text-center max-w-2xl mx-auto mb-20 pidea-header">
      <h2 class="font-outfit text-3xl sm:text-5xl font-extrabold text-white tracking-tight uppercase leading-none mb-6">
        The PIDEA <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyber-gold to-white">Showcase</span>
      </h2>
      <p class="font-exo text-sm sm:text-base text-cyber-gray leading-relaxed">
        Building inventive pipelines designed to engineer solutions for complex digital challenges, establishing precise and professional web infrastructures.
      </p>
    </div>

    <!-- Venture Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 w-full pidea-cards-grid">
      
      <!-- Venture Card 1 -->
      <div class="pidea-card glass-panel-gold p-8 rounded-3xl border border-cyber-gold/10 hover:border-cyber-gold/40 hover:-translate-y-1.5 transition-all duration-500 flex flex-col justify-between group">
        <div>
          <div class="w-12 h-12 rounded-2xl bg-cyber-gold/10 flex items-center justify-center text-cyber-gold mb-6 group-hover:scale-115 transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a3 3 0 00-3-3H7.5m4.5 3a3 3 0 013-3H16.5m-1.5-6h-3.75a3 3 0 00-3 3v10.5a3 3 0 003 3H16.5a3 3 0 003-3V6a3 3 0 00-3-3H15z" />
            </svg>
          </div>
          <h3 class="font-outfit text-lg font-bold text-white mb-3 uppercase tracking-wider group-hover:text-cyber-gold transition-colors duration-300">The Pi-Bulb Concept</h3>
          <p class="font-exo text-sm text-cyber-gray/90 leading-relaxed mb-6">
            Establishing structured, creative pipelines to formulate mathematical, logic-driven concepts for visual identities and brand scaling.
          </p>
        </div>
        <a href="#contact" class="font-outfit text-xs tracking-widest uppercase text-cyber-gold group-hover:text-white transition-colors duration-300 flex items-center gap-2">
          Explore concept <span>&rarr;</span>
        </a>
      </div>

      <!-- Venture Card 2 -->
      <div class="pidea-card glass-panel-gold p-8 rounded-3xl border border-cyber-gold/10 hover:border-cyber-gold/40 hover:-translate-y-1.5 transition-all duration-500 flex flex-col justify-between group">
        <div>
          <div class="w-12 h-12 rounded-2xl bg-cyber-gold/10 flex items-center justify-center text-cyber-gold mb-6 group-hover:scale-115 transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
            </svg>
          </div>
          <h3 class="font-outfit text-lg font-bold text-white mb-3 uppercase tracking-wider group-hover:text-cyber-gold transition-colors duration-300">Universal Systems</h3>
          <p class="font-exo text-sm text-cyber-gray/90 leading-relaxed mb-6">
            Engineering highly responsive, system-agnostic digital platforms tailored to parse perfectly across all modern mobile and desktop dimensions.
          </p>
        </div>
        <a href="#contact" class="font-outfit text-xs tracking-widest uppercase text-cyber-gold group-hover:text-white transition-colors duration-300 flex items-center gap-2">
          Explore system <span>&rarr;</span>
        </a>
      </div>

      <!-- Venture Card 3 -->
      <div class="pidea-card glass-panel-gold p-8 rounded-3xl border border-cyber-gold/10 hover:border-cyber-gold/40 hover:-translate-y-1.5 transition-all duration-500 flex flex-col justify-between group">
        <div>
          <div class="w-12 h-12 rounded-2xl bg-cyber-gold/10 flex items-center justify-center text-cyber-gold mb-6 group-hover:scale-115 transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-.778.099-1.533.284-2.253" />
            </svg>
          </div>
          <h3 class="font-outfit text-lg font-bold text-white mb-3 uppercase tracking-wider group-hover:text-cyber-gold transition-colors duration-300">Inventive Ventures</h3>
          <p class="font-exo text-sm text-cyber-gray/90 leading-relaxed mb-6">
            Launching cutting-edge digital ventures built on fast, light-speed engines designed to scale professionally in real-world environments.
          </p>
        </div>
        <a href="#contact" class="font-outfit text-xs tracking-widest uppercase text-cyber-gold group-hover:text-white transition-colors duration-300 flex items-center gap-2">
          Explore ventures <span>&rarr;</span>
        </a>
      </div>

    </div>

  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

    // Register ScrollTrigger with GSAP
    gsap.registerPlugin(ScrollTrigger);

    // Stagger fade the PIDEA header elements
    gsap.from('.pidea-logo-container', {
      opacity: 0,
      scale: 0.92,
      duration: 1.0,
      scrollTrigger: {
        trigger: '#pidea',
        start: 'top 75%',
        toggleActions: 'play none none none'
      }
    });

    gsap.from('.pidea-header', {
      opacity: 0,
      y: 20,
      duration: 0.8,
      delay: 0.2,
      scrollTrigger: {
        trigger: '#pidea',
        start: 'top 75%',
        toggleActions: 'play none none none'
      }
    });

    // Stagger fade-in/slide-up cards on scroll entry
    gsap.from('.pidea-card', {
      opacity: 0,
      y: 35,
      duration: 0.8,
      stagger: 0.15,
      delay: 0.3,
      scrollTrigger: {
        trigger: '.pidea-cards-grid',
        start: 'top 80%',
        toggleActions: 'play none none none'
      }
    });
  });
</script>
