---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Bio from '../components/Bio.astro';
import Pidea from '../components/Pidea.astro';
import Footer from '../components/Footer.astro';
import ParticleBg from '../components/ParticleBg.astro';
---

<Layout>
  <!-- Futuristic Canvas Particle Network Background (Runs globally behind all elements) -->
  <ParticleBg />

  <!-- Fixed Blurred Glass Navigation Bar -->
  <Header />

  <!-- Scroll-Triggered Parallax Cherry Sunset Bridge Hero Section -->
  <Hero />

  <!-- Cybernetic Grid Biography & Library Suit Portrait Section -->
  <Bio />

  <!-- Golden pi-bulb orb Ventures & PIDEA Innovation Section -->
  <Pidea />

  <!-- Glassmorphic Form & Closing Signature Footer -->
  <Footer />
</Layout>
